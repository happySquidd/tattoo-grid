---
import BaseLayout from "~/layouts/BaseLayout.astro"
---
<BaseLayout title="Contact" description="Reach out with questions or tattoo requests.">

  <main class="flex flex-col items-center px-6 pt-20 pb-28">
    <div class="w-full max-w-lg flex flex-col items-center gap-12">

      <div class="flex flex-col items-center gap-5 text-center">
        <p class="text-xs font-semibold uppercase tracking-[0.3em] text-gray-400 dark:text-gray-500">Let's talk</p>
        <h1 class="text-5xl font-black italic text-gray-900 dark:text-white">Contact Me</h1>
        <div class="w-8 h-px bg-gray-300 dark:bg-gray-700"></div>
        <p class="text-gray-500 dark:text-gray-400 leading-relaxed">Feel free to reach out if you have any questions or a tattoo request. I will respond as soon as I can!</p>
      </div>

      <form class="w-full flex flex-col gap-4" enctype="multipart/form-data">

        <input
          class="form-input"
          type="text" id="name" name="name" required placeholder="Your name" />

        <input
          class="form-input"
          type="email" id="email" name="email" required placeholder="Email" />

        <textarea
          class="form-input resize-none h-32"
          id="message" name="message" required placeholder="Questions or requests"></textarea>

        <div class="flex flex-col gap-3">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-gray-400 dark:text-gray-500">Attach reference images</p>
          <input class="file-input" type="file" id="pic1" name="pic1" accept="image/*" />
          <input class="file-input" type="file" id="pic2" name="pic2" accept="image/*" />
          <input class="file-input" type="file" id="pic3" name="pic3" accept="image/*" />
        </div>

        <button type="submit" class="w-full text-sm font-medium py-3 rounded-full border border-gray-800 dark:border-gray-200 text-gray-800 dark:text-gray-200 hover:bg-black hover:text-white hover:border-black dark:hover:bg-white dark:hover:text-black dark:hover:border-white transition-all duration-200 cursor-pointer">
          Submit
        </button>

      </form>

    </div>
  </main>

</BaseLayout>

<style>
  .form-input {
    width: 100%;
    padding: 0.625rem 0.875rem;
    font-size: 0.875rem;
    border-radius: 0.5rem;
    border: 1px solid #d1d5db;
    background-color: transparent;
    color: #111827;
    outline: none;
    transition: border-color 0.15s;
  }

  .form-input::placeholder {
    color: #9ca3af;
  }

  .form-input:focus {
    border-color: #6b7280;
  }

  .file-input {
    display: block;
    width: 100%;
    font-size: 0.8rem;
    color: #9ca3af;
    cursor: pointer;
  }

  .file-input::file-selector-button {
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.25rem 0.75rem;
    margin-right: 0.75rem;
    border: 1px solid #d1d5db;
    border-radius: 999px;
    background: transparent;
    color: #374151;
    cursor: pointer;
    transition: all 0.15s;
  }

  .file-input::file-selector-button:hover {
    background: #111827;
    color: white;
    border-color: #111827;
  }

  @media (prefers-color-scheme: dark) {
    .form-input {
      border-color: #374151;
      color: #f9fafb;
    }

    .form-input:focus {
      border-color: #6b7280;
    }

    .file-input::file-selector-button {
      border-color: #374151;
      color: #d1d5db;
    }

    .file-input::file-selector-button:hover {
      background: white;
      color: black;
      border-color: white;
    }
  }
</style>
